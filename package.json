{
  "name": "n8n-nodes-k2think",
  "version": "0.1.1",
  "description": "n8n community node for the K2 Think V2 reasoning model (MBZUAI-IFM), OpenAI-compatible gateway at api.k2think.ai",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "k2think",
    "k2-think",
    "mbzuai",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "homepage": "https://ifm.ai",
  "author": {
    "name": "iayazedan",
    "email": "contactmalekchat@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iayazedan/n8n-nodes-k2think.git"
  },
  "bugs": {
    "url": "https://github.com/iayazedan/n8n-nodes-k2think/issues"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/K2ThinkApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/K2Think/K2Think.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
